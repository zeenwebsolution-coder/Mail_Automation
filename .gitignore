*.so

# Django stuff
*.log
db.sqlite3
media/
staticfiles/

# Ignore ALL migrations
**/migrations/*
!**/migrations/__init__.py

# Environment variables
.env
.env.*
*.env

# Virtual environments
myenv/
venv/
env/
ENV/

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
# OS files
.DS_Store
Thumbs.db

# Private / Secrets
.env
*.pyc

# Local Test files
test.py
test_api.py

# Documentation (optional, but keep if you want it private)
DOCUMENTATION.md

# Python packaging
build/
dist/
*.egg-info/
.eggs/

# Testing / coverage
.coverage
htmlcov/
.pytest_cache/

# Ignore everything inside .ignoreme folder
.ignoreme/

# Node (if using frontend with Django)
node_modules/

# Misc
*.bak
*.tmp
*/migrations/*
